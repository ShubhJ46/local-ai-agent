# Ollama endpoint and model configuration
OLLAMA_BASE_URL=http://localhost:11434
EMBEDDING_MODEL=nomic-embed-text
LLM_MODEL=qwen2.5-coder:3b
REQUEST_TIMEOUT_SECONDS=120

# Directory used by embedded Qdrant. Keep it outside source control.
VECTOR_STORE_PATH=./qdrant_data

# Optional. Embedded Qdrant locks its directory, so only one process may use
# an index at a time. Point this at a Qdrant server to share one index
# between the CLI and the HTTP API.
# QDRANT_URL=http://localhost:6333
